.page {
  height: 100vh;
  background: #f5f5f5;
  display: flex;
  flex-direction: column;
}

.nav {
  background: #fff;
  color: #333;
  border-bottom: 1px solid #eee;
}

.nav-inner {
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 12px;
}

.nav-back {
  width: 88px;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  gap: 4px;
}

.nav-back-icon {
  font-size: 28px;
  line-height: 1;
}

.nav-back-text {
  font-size: 16px;
}

.nav-title {
  flex: 1;
  text-align: center;
  font-size: 18px;
  font-weight: 700;
  letter-spacing: 1px;
}

.nav-right {
  width: 88px;
  height: 44px;
}

.content {
  flex: 1;
  overflow-y: auto;
}

/* 加载中 */
.loading {
  padding: 80rpx 0;
  text-align: center;
  color: #999;
  font-size: 28rpx;
}

/* 列表 */
.list {
  padding: 20rpx 32rpx;
}

.item {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.item-main {
  padding: 32rpx;
}

/* 职位信息 */
.item-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.job-title {
  flex: 1;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.4;
  margin-right: 20rpx;
}

.job-salary {
  font-size: 32rpx;
  font-weight: 700;
  color: #ff6a00;
  white-space: nowrap;
}

/* 公司信息 */
.item-company {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-top: 1rpx solid #f0f0f0;
  border-bottom: 1rpx solid #f0f0f0;
  margin-bottom: 20rpx;
}

.company-logo {
  width: 80rpx;
  height: 80rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.company-info {
  flex: 1;
}

.company-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.company-location {
  font-size: 24rpx;
  color: #999;
}

/* 底部信息 */
.item-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.apply-time {
  font-size: 24rpx;
  color: #999;
}

.status {
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.status-pending {
  background: #e8f4ff;
  color: #0052d9;
}

.status-viewed {
  background: #fff4e6;
  color: #ff9800;
}

.status-interview {
  background: #e8f5e9;
  color: #4caf50;
}

.status-offer {
  background: #f3e5f5;
  color: #9c27b0;
}

.status-rejected {
  background: #ffebee;
  color: #f44336;
}

/* 操作按钮 */
.item-actions {
  padding: 0 32rpx 32rpx;
  display: flex;
  justify-content: flex-end;
}

.btn-cancel {
  padding: 12rpx 32rpx;
  background: #fff;
  color: #666;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  font-size: 26rpx;
  line-height: 1;
}

.btn-cancel::after {
  border: none;
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 32rpx;
  opacity: 0.6;
}

.empty-title {
  color: #999;
  font-size: 32rpx;
  margin-bottom: 16rpx;
}

.empty-desc {
  color: #ccc;
  font-size: 26rpx;
}
